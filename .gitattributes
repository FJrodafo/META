# ===============================
# Line ending normalization (EOL)
# ===============================

# Automatically detects text files and normalizes them to LF (Unix)
# Git will convert CRLF -> LF on commit
* text=auto eol=lf

# Force CRLF (Windows) for specific scripts
# Useful because some Windows environments require this format
*.bat text eol=crlf
*.cmd text eol=crlf
*.ahk text eol=crlf

# ============================================
# GitHub Linguist configuration
# (how GitHub calculates repository languages)
# ============================================

# Exclude the "wordpress" directory from GitHub Linguist analysis
# This folder contains static files generated by the Simply Static plugin (WordPress)
# These files are build artifacts (HTML, JS, CSS, etc.), not source code

# Mark them as generated so they are ignored in language statistics
wordpress/** linguist-generated=true

# NOTE:
# The "wordpress" folder is intentionally excluded because it contains
# generated static output, which would otherwise skew language statistics.
